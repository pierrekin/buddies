# Git LFS — large binary part assets generated by `ato create part`.
# Scope to binaries only; the build-critical text files (.ato, .kicad_sym,
# .kicad_mod) stay in normal git so they remain diffable and greppable.
# The `-text` flag also disables EOL normalization (kills the CRLF warnings).

*.step  filter=lfs diff=lfs merge=lfs -text
*.STEP  filter=lfs diff=lfs merge=lfs -text
*.stp   filter=lfs diff=lfs merge=lfs -text
*.pdf   filter=lfs diff=lfs merge=lfs -text
